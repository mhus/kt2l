<configuration>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%date %highlight(%-5level) %msg %cyan(%logger{5}@[%-4.30thread]) %mdc{trace_id}%n</pattern>
    </encoder>
  </appender>

  <logger name="com.vaadin.flow.server.communication" level="INFO" />
  <root level="DEBUG">
    <appender-ref ref="STDOUT" />
  </root>
</configuration>
